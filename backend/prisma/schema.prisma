generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                                                              Int                              @id @default(autoincrement())
  email                                                                           String?
  password                                                                        String
  firstName                                                                       String?
  lastName                                                                        String?
  address                                                                         String?
  age                                                                             Int?
  createdAt                                                                       DateTime                         @default(now())
  updatedAt                                                                       DateTime
  mobile                                                                          String                           @unique
  otp                                                                             Int?
  otpCreatedAt                                                                    DateTime?
  userTypeId                                                                      Int                              @default(1)
  active                                                                          Boolean                          @default(true)
  createdBy                                                                       Int?
  userName                                                                        String?
  depotId                                                                         Int?
  depotStationId                                                                  Int?
  employeeId                                                                      String?
  AgentCommissionTransactions                                                     AgentCommissionTransactions[]
  AgentPaymentTransactions_AgentPaymentTransactions_createdByIdToUser             AgentPaymentTransactions[]       @relation("AgentPaymentTransactions_createdByIdToUser")
  AgentPaymentTransactions_AgentPaymentTransactions_uuidToUser                    AgentPaymentTransactions[]       @relation("AgentPaymentTransactions_uuidToUser")
  AlcobrakeDeviceStatusLog                                                        AlcobrakeDeviceStatusLog[]
  AlcoholTestResult                                                               AlcoholTestResult[]
  BoardingPoints                                                                  BoardingPoints[]
  BreakPadReplacements                                                            BreakPadReplacements[]
  CaptainIncentives                                                               CaptainIncentives[]
  DiscountStrategies_DiscountStrategies_createdByIdToUser                         DiscountStrategies[]             @relation("DiscountStrategies_createdByIdToUser")
  DiscountStrategies_DiscountStrategies_modifiedByIdToUser                        DiscountStrategies[]             @relation("DiscountStrategies_modifiedByIdToUser")
  DroppingPoints                                                                  DroppingPoints[]
  PromiseTransactionApprovals                                                     PromiseTransactionApprovals[]
  PromiseTransactionRequests                                                      PromiseTransactionRequests[]
  ReservedTicketSeats                                                             ReservedTicketSeats[]
  Tasks_Tasks_assignedToIdToUser                                                  Tasks[]                          @relation("Tasks_assignedToIdToUser")
  Tasks_Tasks_createdByIdToUser                                                   Tasks[]                          @relation("Tasks_createdByIdToUser")
  TempTicketBill                                                                  TempTicketBill[]
  TempTickets                                                                     TempTickets[]
  TicketTransactions                                                              TicketTransactions[]
  TripBoardingPointTimingUpdates                                                  TripBoardingPointTimingUpdates[]
  TripBoardingPointsDelay                                                         TripBoardingPointsDelay[]
  TripBreakdownQuestions                                                          TripBreakdownQuestions[]
  TripBreakdowns                                                                  TripBreakdowns[]
  TripCancellations_TripCancellations_ApprovedByIdToUser                          TripCancellations[]              @relation("TripCancellations_ApprovedByIdToUser")
  TripCancellations_TripCancellations_createdByIdToUser                           TripCancellations[]              @relation("TripCancellations_createdByIdToUser")
  TripDelays_TripDelays_ApprovedByIdToUser                                        TripDelays[]                     @relation("TripDelays_ApprovedByIdToUser")
  TripDelays_TripDelays_createdByIdToUser                                         TripDelays[]                     @relation("TripDelays_createdByIdToUser")
  TripDiscounts_TripDiscounts_createdByIdToUser                                   TripDiscounts[]                  @relation("TripDiscounts_createdByIdToUser")
  TripDiscounts_TripDiscounts_modifiedByIdToUser                                  TripDiscounts[]                  @relation("TripDiscounts_modifiedByIdToUser")
  TripDroppingPointTimingUpdates                                                  TripDroppingPointTimingUpdates[]
  TripDroppingPointsDelay                                                         TripDroppingPointsDelay[]
  TripFareHistory                                                                 TripFareHistory[]
  TripQuestions                                                                   TripQuestions[]
  TripReassigns_TripReassigns_approvedByIdToUser                                  TripReassigns[]                  @relation("TripReassigns_approvedByIdToUser")
  TripReassigns_TripReassigns_captainIdToUser                                     TripReassigns[]                  @relation("TripReassigns_captainIdToUser")
  TripReassigns_TripReassigns_coCaptainIdToUser                                   TripReassigns[]                  @relation("TripReassigns_coCaptainIdToUser")
  TripReassigns_TripReassigns_createdByIdToUser                                   TripReassigns[]                  @relation("TripReassigns_createdByIdToUser")
  TripReassigns_TripReassigns_prevCaptainIdToUser                                 TripReassigns[]                  @relation("TripReassigns_prevCaptainIdToUser")
  TripReassigns_TripReassigns_prevCoCaptainIdToUser                               TripReassigns[]                  @relation("TripReassigns_prevCoCaptainIdToUser")
  TripSeats                                                                       TripSeats[]
  TripUserAttributes                                                              TripUserAttributes[]
  Trips_Trips_captainIdToUser                                                     Trips[]                          @relation("Trips_captainIdToUser")
  Trips_Trips_createdByIdToUser                                                   Trips[]                          @relation("Trips_createdByIdToUser")
  TyreSwitches                                                                    TyreSwitches[]
  TyresQuestions                                                                  TyresQuestions[]
  User                                                                            User?                            @relation("UserToUser", fields: [createdBy], references: [id])
  other_User                                                                      User[]                           @relation("UserToUser")
  Depots                                                                          Depots?                          @relation(fields: [depotId], references: [id])
  Stations                                                                        Stations?                        @relation(fields: [depotStationId], references: [id])
  UserTypes                                                                       UserTypes                        @relation(fields: [userTypeId], references: [id])
  UserAgentBalanceHistory                                                         UserAgentBalanceHistory[]
  UserAgentDetails_UserAgentDetails_salesPersonIdToUser                           UserAgentDetails[]               @relation("UserAgentDetails_salesPersonIdToUser")
  UserAgentDetails                                                                UserAgentDetails?
  UserAnalyticsEvent                                                              UserAnalyticsEvent[]
  UserAttribute                                                                   UserAttribute[]
  UserMetaData                                                                    UserMetaData[]
  UserMobileTokens                                                                UserMobileTokens[]
  UserShifts                                                                      UserShifts[]
  UserSpecificPrivileges                                                          UserSpecificPrivileges[]
  UserTokens                                                                      UserTokens[]
  VehicleComponentObservations_VehicleComponentObservations_createdByIdToUser     VehicleComponentObservations[]   @relation("VehicleComponentObservations_createdByIdToUser")
  VehicleComponentObservations_VehicleComponentObservations_resolvedByIdToUser    VehicleComponentObservations[]   @relation("VehicleComponentObservations_resolvedByIdToUser")
  VehicleLiveComponentsHistory_VehicleLiveComponentsHistory_installedByIdToUser   VehicleLiveComponentsHistory[]   @relation("VehicleLiveComponentsHistory_installedByIdToUser")
  VehicleLiveComponentsHistory_VehicleLiveComponentsHistory_uninstalledByIdToUser VehicleLiveComponentsHistory[]   @relation("VehicleLiveComponentsHistory_uninstalledByIdToUser")
  VehicleObservations                                                             VehicleObservations[]
  VehicleQuestions                                                                VehicleQuestions[]
  StationsToUser                                                                  StationsToUser[]
  tripCaptains                                                                    tripCaptains[]
  tripReassignCaptains                                                            tripReassignCaptains[]
  tripReassignPreviousCaptains                                                    tripReassignPreviousCaptains[]
  alcoholInitiateHistory                                                          alcoholInitiateHistory[]
}

model AgentCommissionTransactions {
  id                                              Int                                               @id @default(autoincrement())
  uuid                                            Int
  financialTransactionType                        FinanceTransactionTypes                           @default(Credit)
  amount                                          Decimal
  loaderFee                                       Decimal                                           @default(0)
  markup                                          Decimal                                           @default(0)
  comment                                         String?
  createdAt                                       DateTime                                          @default(now())
  active                                          Boolean                                           @default(true)
  User                                            User                                              @relation(fields: [uuid], references: [id])
  AgentCommissionTransactionsToTicketTransactions AgentCommissionTransactionsToTicketTransactions[]
}

model AgentPaymentTransactions {
  id                                              Int                         @id @default(autoincrement())
  uuid                                            Int
  amount                                          Decimal
  paymentId                                       Int?                        @unique
  comment                                         String?
  createdById                                     Int
  createdAt                                       DateTime                    @default(now())
  active                                          Boolean                     @default(true)
  reason                                          RechargeReason?
  remarks                                         String?                     @db.VarChar
  updatedAt                                       DateTime?
  User_AgentPaymentTransactions_createdByIdToUser User                        @relation("AgentPaymentTransactions_createdByIdToUser", fields: [createdById], references: [id])
  PaymentGatewayTransactions                      PaymentGatewayTransactions? @relation(fields: [paymentId], references: [id])
  User_AgentPaymentTransactions_uuidToUser        User                        @relation("AgentPaymentTransactions_uuidToUser", fields: [uuid], references: [id])
}

model Amenities {
  id                  Int                   @id @default(autoincrement())
  name                String
  description         String
  image               String
  icon                String
  active              Boolean               @default(true)
  AmenitiesToServices AmenitiesToServices[]
  AmenitiesToTrips    AmenitiesToTrips[]
}

model BoardingPoints {
  id                      Int                       @id @default(autoincrement())
  name                    String
  stationId               Int
  latitude                Float
  longitude               Float
  landmark                String
  locationURL             String
  locationURL360          String
  mobile                  String?
  createdById             Int
  active                  Boolean                   @default(true)
  User                    User                      @relation(fields: [createdById], references: [id])
  Stations                Stations                  @relation(fields: [stationId], references: [id])
  RescheduleTicketSeats   RescheduleTicketSeats[]
  ReservedTickets         ReservedTickets[]
  ServiceBoardingPoints   ServiceBoardingPoints[]
  TripBoardingPoints      TripBoardingPoints[]
  TripBoardingPointsDelay TripBoardingPointsDelay[]

  @@index([stationId])
}

model BreakdownReasons {
  id             Int              @id @default(autoincrement())
  name           String
  active         Boolean          @default(true)
  category       String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime?
  TripBreakdowns TripBreakdowns[]
}

model CancellationPolicies {
  id                                                                              Int                         @id @default(autoincrement())
  name                                                                            String
  active                                                                          Boolean                     @default(true)
  customerActive                                                                  Boolean                     @default(true)
  coinsPolicy                                                                     Boolean                     @default(false)
  CancellationPolicySlabs                                                         CancellationPolicySlabs[]
  ReservedTickets_ReservedTickets_baseCancellationPolicyIdToCancellationPolicies  ReservedTickets[]           @relation("ReservedTickets_baseCancellationPolicyIdToCancellationPolicies")
  ReservedTickets_ReservedTickets_coinsCancellationPolicyIdToCancellationPolicies ReservedTickets[]           @relation("ReservedTickets_coinsCancellationPolicyIdToCancellationPolicies")
  TicketCancellationDetails                                                       TicketCancellationDetails[]
}

model CancellationPolicySlabs {
  id                   Int                  @id @default(autoincrement())
  timetoStartHours     Int
  percentageRefund     Int
  policyId             Int
  active               Boolean              @default(true)
  CancellationPolicies CancellationPolicies @relation(fields: [policyId], references: [id])
}

model CancellationReasons {
  id                Int                 @id @default(autoincrement())
  name              String
  active            Boolean             @default(true)
  category          String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime?
  TripBreakdowns    TripBreakdowns[]
  TripCancellations TripCancellations[]
  Trips             Trips[]
}

model CustomerTokens {
  customerId   Int
  refreshToken String
  createdAt    DateTime  @default(now())
  deviceId     String    @default("FreshBus")
  fcmToken     String?
  apnsToken    String?
  Customers    Customers @relation(fields: [customerId], references: [id])

  @@unique([customerId, deviceId])
}

model Customers {
  id                          Int                           @id @default(autoincrement())
  name                        String                        @default("")
  mobile                      String?                       @unique
  email                       String?
  otp                         Int?
  otpCreatedAt                DateTime?
  address                     String?
  state                       String?
  age                         Int?                          @default(0)
  gender                      Gender                        @default(Male)
  consent                     Boolean                       @default(false)
  direct                      Boolean                       @default(true)
  createdAt                   DateTime                      @default(now())
  availableCoins              Int                           @default(0)
  availablePasses             Int                           @default(0)
  active                      Boolean                       @default(true)
  imageURL                    String?
  kilometersTravelled         Int                           @default(0)
  pincode                     String?
  referralCode                String?                       @unique
  referredById                Int?
  lastSignIn                  DateTime                      @default(now())
  abhibusJoinDate             DateTime?
  joinDate                    DateTime?
  offlineJoinDate             DateTime?
  onlineJoinDate              DateTime?
  paytmJoinDate               DateTime?
  redbusJoinDate              DateTime?
  isMobileLoggedIn            Boolean                       @default(false)
  isNewUser                   Boolean                       @default(true)
  appVersion                  String?
  hashId                      String?                       @unique
  dateOfBirth                 DateTime?
  dobUpdatedOnce              Boolean?
  BookingAdAttribution        BookingAdAttribution[]
  CustomerDiscounts           CustomerDiscounts[]
  CustomerMobileTokens        CustomerMobileTokens[]
  CustomerRewards             CustomerRewards[]
  CustomerTokens              CustomerTokens[]
  CustomerUdf                 CustomerUdf[]
  Customers                   Customers?                    @relation("CustomersToCustomers", fields: [referredById], references: [id])
  other_Customers             Customers[]                   @relation("CustomersToCustomers")
  FeedbackResponses           FeedbackResponses[]
  FreshCardOffer              FreshCardOffer[]
  FreshCardPurchases          FreshCardPurchases[]
  FreshCardTicketTransactions FreshCardTicketTransactions[]
  FreshPassPurchases          FreshPassPurchases[]
  FreshPassTicketTransactions FreshPassTicketTransactions[]
  GreenCoinTransactions       GreenCoinTransactions[]
  InstallReferrerEvent        InstallReferrerEvent[]
  Passengers                  Passengers[]
  ReservedTickets             ReservedTickets[]
}

model DelayIntervals {
  id               Int          @id @default(autoincrement())
  name             String
  active           Boolean      @default(true)
  approvalRequired Boolean      @default(false)
  TripDelays       TripDelays[]
}

model DelayReasons {
  id          Int          @id @default(autoincrement())
  name        String
  active      Boolean      @default(true)
  subCategory String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime?
  TripDelays  TripDelays[]
}

model DroppingPoints {
  id                      Int                       @id @default(autoincrement())
  name                    String
  stationId               Int
  latitude                Float
  longitude               Float
  landmark                String
  locationURL             String
  locationURL360          String
  mobile                  String?
  createdById             Int
  active                  Boolean                   @default(true)
  User                    User                      @relation(fields: [createdById], references: [id])
  Stations                Stations                  @relation(fields: [stationId], references: [id])
  RescheduleTicketSeats   RescheduleTicketSeats[]
  ReservedTickets         ReservedTickets[]
  ServiceDroppingPoints   ServiceDroppingPoints[]
  TripDroppingPoints      TripDroppingPoints[]
  TripDroppingPointsDelay TripDroppingPointsDelay[]
}

model FeedbackQuestions {
  id                Int                 @id @default(autoincrement())
  name              String
  active            Boolean             @default(true)
  description       String
  negative          String
  positive          String
  order             Int?
  FeedbackResponses FeedbackResponses[]
}

model FeedbackResponses {
  id                Int               @id @default(autoincrement())
  questionId        Int
  customerId        Int?
  ticketId          Int
  answer            String
  createdAt         DateTime          @default(now())
  comment           String?
  Customers         Customers?        @relation(fields: [customerId], references: [id])
  FeedbackQuestions FeedbackQuestions @relation(fields: [questionId], references: [id])
  ReservedTickets   ReservedTickets   @relation(fields: [ticketId], references: [id])

  @@unique([ticketId, questionId])
}

model FreshPass {
  id                 Int                  @id @default(autoincrement())
  name               String
  daysEnabled        Int                  @default(127)
  fare               Decimal
  tax                Decimal
  seats              Int
  usage              Int
  Limit              Int
  active             Boolean              @default(true)
  discount           Decimal              @default(0)
  FreshPassPurchases FreshPassPurchases[]
}

model FreshPassPurchases {
  id                          Int                           @id @default(autoincrement())
  customerId                  Int
  amount                      Decimal
  tax                         Decimal
  giftCode                    String?                       @unique
  paymentId                   Int?
  comment                     String?
  freshpassId                 Int
  createdAt                   DateTime                      @default(now())
  active                      Boolean                       @default(true)
  Customers                   Customers                     @relation(fields: [customerId], references: [id])
  FreshPass                   FreshPass                     @relation(fields: [freshpassId], references: [id])
  PaymentGatewayTransactions  PaymentGatewayTransactions?   @relation(fields: [paymentId], references: [id])
  FreshPassTicketTransactions FreshPassTicketTransactions[]
}

model FreshPassTicketTransactions {
  id                     Int                     @id @default(autoincrement())
  customerId             Int
  freshpassTransactionId Int?
  financeTransactionType FinanceTransactionTypes @default(Debit)
  passes                 Int
  reference              String?
  comment                String?
  ticketTransactionId    Int?                    @unique
  createdAt              DateTime                @default(now())
  active                 Boolean                 @default(true)
  freshPassId            Int?
  currentPasses          Int                     @default(0)
  Customers              Customers               @relation(fields: [customerId], references: [id])
  FreshPassPurchases     FreshPassPurchases?     @relation(fields: [freshpassTransactionId], references: [id])
  TicketTransactions     TicketTransactions?     @relation(fields: [ticketTransactionId], references: [id])
}

model GlobalConfigurations {
  id     Int     @id @default(autoincrement())
  name   String
  value  String
  active Boolean @default(true)
}

model GreenCoinTransactions {
  id                                                                                            Int                              @id @default(autoincrement())
  customerId                                                                                    Int
  financeTransactionType                                                                        FinanceTransactionTypes          @default(Debit)
  transactionType                                                                               GreenCoinTransactionTypes        @default(Booked)
  coins                                                                                         Int
  reference                                                                                     String?
  comment                                                                                       String?
  transactionId                                                                                 Int?
  createdAt                                                                                     DateTime                         @default(now())
  active                                                                                        Boolean                          @default(true)
  currentCoins                                                                                  Int                              @default(0)
  expiryAt                                                                                      DateTime?                        @db.Timestamp(6)
  remainingCoins                                                                                Int?
  availableAt                                                                                   DateTime?
  blockId                                                                                       Int?
  CustomerRewards                                                                               CustomerRewards[]
  Customers                                                                                     Customers                        @relation(fields: [customerId], references: [id])
  TicketTransactions                                                                            TicketTransactions?              @relation(fields: [transactionId], references: [id])
  GreenCoinsSubDebitTransactions_GreenCoinsSubDebitTransactions_creditIdToGreenCoinTransactions GreenCoinsSubDebitTransactions[] @relation("GreenCoinsSubDebitTransactions_creditIdToGreenCoinTransactions")
  GreenCoinsSubDebitTransactions_GreenCoinsSubDebitTransactions_debitIdToGreenCoinTransactions  GreenCoinsSubDebitTransactions[] @relation("GreenCoinsSubDebitTransactions_debitIdToGreenCoinTransactions")
  ReservedTickets                                                                               ReservedTickets[]
}

model ManageUserPermissions {
  id           Int       @id @default(autoincrement())
  userTypeId   Int
  privilegeBit Int
  UserTypes    UserTypes @relation(fields: [userTypeId], references: [id])
}

model NotBoardedReasons {
  id                  Int                   @id @default(autoincrement())
  name                String
  active              Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime?
  ReservedTicketSeats ReservedTicketSeats[]
}

model Passengers {
  id                  Int                   @id @default(autoincrement())
  name                String?
  customerId          Int
  age                 Int?
  gender              Gender                @default(Male)
  createdAt           DateTime              @default(now())
  active              Boolean               @default(true)
  Customers           Customers             @relation(fields: [customerId], references: [id])
  ReservedTicketSeats ReservedTicketSeats[]

  @@unique([customerId, name, age, gender])
}

model PaymentGatewayTransactions {
  id                       Int                       @id @default(autoincrement())
  createdAt                DateTime                  @default(now())
  transactionId            String
  orderId                  String                    @unique
  amount                   Decimal
  paymentGatewayName       String                    @default("JUSPAY")
  status                   String                    @default("NEW")
  pollingTriggered         Boolean                   @default(false)
  updatedAt                DateTime?
  response                 Json?
  AgentPaymentTransactions AgentPaymentTransactions?
  FreshCardPurchases       FreshCardPurchases[]
  FreshPassPurchases       FreshPassPurchases[]
  TicketTransactions       TicketTransactions[]
}

model QuestionCategories {
  id         Int         @id @default(autoincrement())
  name       String
  order      Int
  userTypeId Int
  active     Boolean     @default(true)
  UserTypes  UserTypes   @relation(fields: [userTypeId], references: [id])
  Questions  Questions[]
}

model QuestionTypes {
  id        Int         @id @default(autoincrement())
  name      String
  active    Boolean     @default(true)
  Questions Questions[]
}

model Questions {
  id                     Int                      @id @default(autoincrement())
  name                   String
  active                 Boolean                  @default(true)
  hint                   String?
  questionTypeId         Int
  categoryId             Int
  maintenanceCategoryId  Int?
  isSleeper              Boolean                  @default(false)
  QuestionCategories     QuestionCategories       @relation(fields: [categoryId], references: [id])
  MaintenanceCategories  MaintenanceCategories?   @relation(fields: [maintenanceCategoryId], references: [id])
  QuestionTypes          QuestionTypes            @relation(fields: [questionTypeId], references: [id])
  TripBreakdownQuestions TripBreakdownQuestions[]
  TripQuestions          TripQuestions[]
  TyresQuestions         TyresQuestions[]
  VehicleQuestions       VehicleQuestions[]
}

model ReservedTicketSeats {
  id                                      Int                                       @id @default(autoincrement())
  amount                                  Decimal
  discount                                Decimal
  commission                              Decimal                                   @default(0)
  loaderFee                               Decimal                                   @default(0)
  markup                                  Decimal                                   @default(0)
  ticketId                                Int
  passengerId                             Int
  seatId                                  Int
  createdAt                               DateTime                                  @default(now())
  isBoarded                               Boolean                                   @default(false)
  isMealProvided                          Boolean                                   @default(false)
  active                                  Boolean                                   @default(true)
  boardedAt                               DateTime?
  boardedById                             Int?
  coins                                   Int                                       @default(0)
  notBoardedReasonId                      Int?
  pass                                    Boolean                                   @default(false)
  kilometersTravelled                     Int                                       @default(300)
  tax                                     Decimal                                   @default(0)
  couponDiscount                          Decimal                                   @default(0)
  employeeCouponId                        Int?
  promise                                 Boolean?
  retentioncoins                          Boolean?
  BoardStatusHistory                      BoardStatusHistory[]
  User                                    User?                                     @relation(fields: [boardedById], references: [id])
  EmployeeCoupons                         EmployeeCoupons?                          @relation(fields: [employeeCouponId], references: [id])
  NotBoardedReasons                       NotBoardedReasons?                        @relation(fields: [notBoardedReasonId], references: [id])
  Passengers                              Passengers                                @relation(fields: [passengerId], references: [id])
  Seats                                   Seats                                     @relation(fields: [seatId], references: [id])
  ReservedTickets                         ReservedTickets                           @relation(fields: [ticketId], references: [id])
  ReservedTicketSeatsToTicketTransactions ReservedTicketSeatsToTicketTransactions[]

  @@index([ticketId])
}

model ReservedTickets {
  id                                                                                   Int                     @id @default(autoincrement())
  customerId                                                                           Int
  serviceId                                                                            Int?
  tripId                                                                               Int
  createdAt                                                                            DateTime                @default(now())
  boardingTime                                                                         DateTime
  boardingPointId                                                                      Int
  droppingTime                                                                         DateTime?
  droppingPointId                                                                      Int
  invoiceNumber                                                                        String                  @default("FRE")
  active                                                                               Boolean                 @default(true)
  tempTicketId                                                                         Int?                    @unique
  mobile                                                                               String?
  name                                                                                 String?
  mainCategory                                                                         MainCategory?
  subCategory                                                                          SubCategory?
  baseCancellationPolicyId                                                             Int                     @default(7)
  coinsCancellationPolicyId                                                            Int                     @default(8)
  didCaptainCall                                                                       Int                     @default(0)
  bookingHashId                                                                        String?
  freshcard                                                                            Int                     @default(0)
  email                                                                                String?
  actualBoardingTime                                                                   DateTime?
  actualDroppingTime                                                                   DateTime?
  communicatedBoardingTime                                                             DateTime?
  communicatedDroppingTime                                                             DateTime?
  boardingCoveredBy                                                                    GPSTelematicsDevice?
  droppingCoveredBy                                                                    GPSTelematicsDevice?
  isBoardingCovered                                                                    Boolean                 @default(false)
  isDroppingCovered                                                                    Boolean                 @default(false)
  loyaltyBonusId                                                                       Int?
  boardingIvr                                                                          DateTime?
  discountId                                                                           Int?
  referredByCaptain                                                                    Boolean                 @default(false)
  assured                                                                              Boolean                 @default(false)
  couponCode                                                                           String?                 @default("")
  couponId                                                                             String?                 @default("")
  BookingAdAttribution_BookingAdAttribution_bookingIdToReservedTickets                 BookingAdAttribution?   @relation("BookingAdAttribution_bookingIdToReservedTickets")
  BookingAdAttribution_BookingAdAttribution_tempTicketIdToReservedTickets              BookingAdAttribution?   @relation("BookingAdAttribution_tempTicketIdToReservedTickets")
  CaptainIncentives                                                                    CaptainIncentives[]
  CustomerDiscounts_CustomerDiscounts_ticketIdToReservedTickets                        CustomerDiscounts[]     @relation("CustomerDiscounts_ticketIdToReservedTickets")
  CustomerRatings                                                                      CustomerRatings?
  FeedbackResponses                                                                    FeedbackResponses[]
  PromiseTransactions                                                                  PromiseTransactions[]
  ReservedTicketSeats                                                                  ReservedTicketSeats[]
  CancellationPolicies_ReservedTickets_baseCancellationPolicyIdToCancellationPolicies  CancellationPolicies    @relation("ReservedTickets_baseCancellationPolicyIdToCancellationPolicies", fields: [baseCancellationPolicyId], references: [id])
  BoardingPoints                                                                       BoardingPoints          @relation(fields: [boardingPointId], references: [id])
  CancellationPolicies_ReservedTickets_coinsCancellationPolicyIdToCancellationPolicies CancellationPolicies    @relation("ReservedTickets_coinsCancellationPolicyIdToCancellationPolicies", fields: [coinsCancellationPolicyId], references: [id])
  Customers                                                                            Customers               @relation(fields: [customerId], references: [id])
  CustomerDiscounts_ReservedTickets_discountIdToCustomerDiscounts                      CustomerDiscounts?      @relation("ReservedTickets_discountIdToCustomerDiscounts", fields: [discountId], references: [id])
  DroppingPoints                                                                       DroppingPoints          @relation(fields: [droppingPointId], references: [id])
